[user]
	name = Stefano Cilloni
	email = dev@nyxgear.com
	
[core]
	excludesFile = ~/.gitignore
	# pager = delta
	autocrlf = input
	editor = vim

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

# [color]
# 	ui = auto

[color "branch"]
	current = red
	local = yellow
	remote = green

[color "diff"]
	meta = cyan
	frag = magenta
	old = red bold
	new = green bold

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[alias]
	st = status -sb
	ci = commit
	co = checkout
	br = branch
	cp = cherry-pick
	branches = branch -avv
	wtf = log --graph --pretty=format:"%C(auto,yellow)%h%C(auto)%d%C(auto,reset)\\ by\\ %C(auto,blue)%an%C(auto,reset),\\ %C(auto,cyan)%ar%C(auto,reset)%n\\ %s%n" --stat
	lg = log --graph --all --stat
	unci = reset HEAD^
	uncommit = reset HEAD^
	ls = ls-files
	ps = push
	lol = log --all --graph --decorate --pretty=oneline --abbrev-commit
	loll = log --all --graph --decorate --pretty=oneline --abbrev-commit --stat

[diff]
    tool = cursor

[difftool "cursor"]
    cmd = cursor --wait --diff $LOCAL $REMOTE

[push]
	default = current

[merge]
	tool = cursor

[mergetool "cursor"]
    cmd = cursor --wait --merge $REMOTE $LOCAL $BASE $MERGED

# Work-only git configuration
[include]
	path = ~/.gitconfig-work
